correlation.mvm <-as.data.frame( sapply(1:nrow(ctrl.mvm), function(i) cor(ctrl.mvm[i, ], rnase.mvm[i, ])))
rownames(correlation.mvm) <- rownames(rnase.mvm)
# Trainingssatz (Zeilen 1 bis 2500)
train_mvm <- data.frame(Korrelation = correlation.mvm[1:2500, ], Shift = shift_mvm_named[1:2500, 2])
# Lineares Regressionsmodell
model_mvm_global <- lm(Shift ~ Korrelation, data = train_mvm)
# Testdaten (Zeilen 2501 bis 3074)
test_mvm <- data.frame(Korrelation = correlation.mvm[2501:3074, ])
# Vorhersagen machen
predictions_mvm <- as.data.frame(predict(model_mvm_global, newdata = test_mvm))
# Vorhersagen auf diskrete Werte abrunden
rounded_predictions_mvm_global <- round(predictions_mvm)
rownames(rounded_predictions_mvm_global) <- rownames(rnase.mvm[2501:3074, ])
